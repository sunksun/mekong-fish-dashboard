# ─────────────────────────────────────────────────────────────
# Mekong Fish Dashboard — Environment Variables Template
# คัดลอกไฟล์นี้เป็น .env.local แล้วเติมค่าจริง (อย่า commit .env.local!)
# ─────────────────────────────────────────────────────────────

# Firebase — Client SDK (public, ปลอดภัยจะ expose ที่ browser)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tracking-fish-app.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tracking-fish-app
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=tracking-fish-app.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK — Server side only (สำหรับ API routes ที่ต้องบายพาส rules)
# วางไฟล์ service account JSON เป็น string 1 บรรทัด หรือใช้แยก env
# ดาวน์โหลดจาก Firebase Console > Project Settings > Service accounts
FIREBASE_SERVICE_ACCOUNT=
# หรือแยกเป็น 3 ตัว (ทางเลือก):
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# JWT (สำรอง, ยังไม่ได้ใช้ทั่วระบบ)
JWT_SECRET=

# App metadata
NEXT_PUBLIC_APP_NAME=Mekong Fish Dashboard
NEXT_PUBLIC_APP_VERSION=1.0.0

# Google Maps API Key (public — restrict ด้วย HTTP referrer ใน Google Cloud Console)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Gemini AI (server side only — สำหรับ /api/chat และ /api/news/generate)
# https://ai.google.dev/
GEMINI_API_KEY=
