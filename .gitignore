# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# firebase
.firebase/
# Firebase service account credentials (NEVER commit!)
*-firebase-adminsdk-*.json
tracking-fish-app-*.json
service-account*.json

# scratch/ad-hoc test scripts (Playwright repro scripts, admin SDK setup/cleanup, etc.)
.scratch-test/

# development and test scripts
test-*.js
test-*.cjs
create-*.js
setup-*.js
check-*.cjs
check-*.js
import-*.cjs
final-test.js
# admin / research scripts (may contain Firebase config)
export_*.mjs
verify_*.mjs

# mock data
src/fish-data.json
src/fish-data-full.json

# csv data files
*.csv

# typescript
*.tsbuildinfo
next-env.d.ts
